{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Signal": {
      "title": "Signal",
      "description": "Trading signal generated by Sentinel",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "symbol": { "type": "string" }
      },
      "required": ["content", "timestamp"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Chat message between user and AI",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "ai"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "Trading journal entry",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "side": { "type": "string" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "pnl": { "type": "number" },
        "reason": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "side", "pnl", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles"
    },
    "/signals/{signalId}": {
      "schema": { "$ref": "#/entities/Signal" },
      "description": "Stores all trading signals"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Stores chat history"
    },
    "/journal/{journalId}": {
      "schema": { "$ref": "#/entities/JournalEntry" },
      "description": "Stores trading journal entries"
    }
  }
}
