{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Signal": {
      "title": "Signal",
      "description": "Trading signal generated by Sentinel",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "symbol": { "type": "string" }
      },
      "required": ["content", "timestamp"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Chat message between user and AI",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "ai"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "timestamp"]
    },
    "TelegramChat": {
      "title": "TelegramChat",
      "description": "Chat history for a specific Telegram user",
      "type": "object",
      "properties": {
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "content": { "type": "string" }
            },
            "required": ["role", "content"]
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["history"]
    },
    "JournalEntry": {
      "title": "JournalEntry",
      "description": "Trading journal entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "symbol": { "type": "string" },
        "side": { "type": "string" },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "stopLoss": { "type": "number" },
        "target1": { "type": "number" },
        "target2": { "type": "number" },
        "pnl": { "type": "number" },
        "reason": { "type": "string" },
        "sentiment": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "side", "pnl", "timestamp"]
    },
    "JournalSummary": {
      "title": "JournalSummary",
      "description": "Auto-generated 12-hour trading journal summary",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "period": { "type": "string" },
        "totalTrades": { "type": "number" },
        "winRate": { "type": "number" },
        "netPnl": { "type": "number" },
        "tradedSymbols": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evaluation": { "type": "string" }
      },
      "required": ["timestamp", "period", "totalTrades", "winRate", "netPnl", "evaluation"]
    },
    "PaperWallet": {
      "title": "PaperWallet",
      "description": "Virtual wallet for paper trading",
      "type": "object",
      "properties": {
        "balance": { "type": "number" },
        "equity": { "type": "number" },
        "freeMargin": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["balance", "equity", "freeMargin", "updatedAt"]
    },
    "PaperPosition": {
      "title": "PaperPosition",
      "description": "Open virtual trading position",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "side": { "type": "string", "enum": ["LONG", "SHORT"] },
        "entryPrice": { "type": "number" },
        "size": { "type": "number" },
        "unrealizedPnl": { "type": "number" },
        "takeProfit": { "type": "number" },
        "stopLoss": { "type": "number" },
        "status": { "type": "string", "enum": ["OPEN"] },
        "openedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "side", "entryPrice", "size", "status", "openedAt"]
    },
    "PaperHistory": {
      "title": "PaperHistory",
      "description": "Closed virtual trading position",
      "type": "object",
      "properties": {
        "symbol": { "type": "string" },
        "side": { "type": "string", "enum": ["LONG", "SHORT"] },
        "entryPrice": { "type": "number" },
        "exitPrice": { "type": "number" },
        "size": { "type": "number" },
        "pnl": { "type": "number" },
        "reason": { "type": "string" },
        "openedAt": { "type": "string", "format": "date-time" },
        "closedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["symbol", "side", "entryPrice", "exitPrice", "size", "pnl", "reason", "openedAt", "closedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles"
    },
    "/signals/{signalId}": {
      "schema": { "$ref": "#/entities/Signal" },
      "description": "Stores all trading signals"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Stores chat history"
    },
    "/telegram_chats/{chatId}": {
      "schema": { "$ref": "#/entities/TelegramChat" },
      "description": "Stores Telegram chat history for Sentinel"
    },
    "/trading_journal/{journalId}": {
      "schema": { "$ref": "#/entities/JournalEntry" },
      "description": "Stores trading journal entries"
    },
    "/journal_summaries/{summaryId}": {
      "schema": { "$ref": "#/entities/JournalSummary" },
      "description": "Stores 12-hour auto-generated journal summaries"
    },
    "/paper_wallet/{walletId}": {
      "schema": { "$ref": "#/entities/PaperWallet" },
      "description": "Stores the virtual wallet balance"
    },
    "/paper_positions/{positionId}": {
      "schema": { "$ref": "#/entities/PaperPosition" },
      "description": "Stores open virtual positions"
    },
    "/paper_history/{historyId}": {
      "schema": { "$ref": "#/entities/PaperHistory" },
      "description": "Stores closed virtual positions"
    }
  }
}
